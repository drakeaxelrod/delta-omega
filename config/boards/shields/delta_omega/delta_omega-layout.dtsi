#include <physical_layouts.dtsi>

/ {
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        // 34-key splay built for Kailh PG1316S (ultra-low-profile SMD,
        // 14 x 14.5 mm body, ~14 mm pitch). Coordinates are normalized to a
        // 1u cell (100 = one key pitch); keycaps fill the cell (95 x 95) to
        // show the small inter-cap gap typical of low-profile caps.
        keys  //                     w  h    x    y     rot    rx     ry
            = <&key_physical_attrs  95  95  15  158 (-2200)   65   208>
            , <&key_physical_attrs  95  95 129   62 (-1200)  179   112>
            , <&key_physical_attrs  95  95 253    3  (-400)  303    53>
            , <&key_physical_attrs  95  95 370   44      0    0     0>
