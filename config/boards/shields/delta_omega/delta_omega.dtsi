#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>
#include <behaviors/rgbled_widget.dtsi>
/ {
	chosen {
		zmk,kscan = &kscan0;
		zmk,physical-layout = &physical_layout0;
    };

	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <10>;
		rows = <4>;
		map = <
                RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)    RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
                RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)    RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
                RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)    RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)
                                        RC(3,3) RC(3,4)    RC(3,5) RC(3,6)
		>;
	};

	kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;

        diode-direction = "col2row";
        row-gpios
            = <&xiao_d 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
        ;

	};

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        kscan = <&kscan0>;
        transform = <&default_transform>;
        // 34-key splay built for Kailh PG1316S (ultra-low-profile SMD,
        // 14 x 14.5 mm body, ~14 mm pitch). Coordinates are normalized to a
        // 1u cell (100 = one key pitch); keycaps fill the cell (95 x 95) to
        // show the small inter-cap gap typical of low-profile caps.
        keys  //                     w  h    x    y     rot    rx     ry
            = <&key_physical_attrs  95  95  15  158 (-2200)   65   208>
            , <&key_physical_attrs  95  95 129   62 (-1200)  179   112>
            , <&key_physical_attrs  95  95 253    3  (-400)  303    53>
            , <&key_physical_attrs  95  95 370   44      0    0     0>
            , <&key_physical_attrs  95  95 470   68      0    0     0>
            , <&key_physical_attrs  95  95 815   68      0    0     0>
            , <&key_physical_attrs  95  95 915   44      0    0     0>
            , <&key_physical_attrs  95  95 1032    3    400 1082    53>
            , <&key_physical_attrs  95  95 1156   62   1200 1206   112>
            , <&key_physical_attrs  95  95 1270  158   2200 1320   208>
            , <&key_physical_attrs  95  95  51  251 (-2200)  101   301>
            , <&key_physical_attrs  95  95 149  160 (-1200)  199   210>
            , <&key_physical_attrs  95  95 260  103  (-400)  310   153>
            , <&key_physical_attrs  95  95 370  144      0    0     0>
            , <&key_physical_attrs  95  95 470  168      0    0     0>
            , <&key_physical_attrs  95  95 815  168      0    0     0>
            , <&key_physical_attrs  95  95 915  144      0    0     0>
            , <&key_physical_attrs  95  95 1025  103    400 1075   153>
            , <&key_physical_attrs  95  95 1136  160   1200 1186   210>
            , <&key_physical_attrs  95  95 1235  251   2200 1285   301>
            , <&key_physical_attrs  95  95  86  343 (-2200)  136   393>
            , <&key_physical_attrs  95  95 169  257 (-1200)  219   307>
            , <&key_physical_attrs  95  95 266  203  (-400)  316   253>
            , <&key_physical_attrs  95  95 370  244      0    0     0>
            , <&key_physical_attrs  95  95 470  268      0    0     0>
            , <&key_physical_attrs  95  95 815  268      0    0     0>
            , <&key_physical_attrs  95  95 915  244      0    0     0>
            , <&key_physical_attrs  95  95 1019  203    400 1069   253>
            , <&key_physical_attrs  95  95 1117  257   1200 1167   307>
            , <&key_physical_attrs  95  95 1199  343   2200 1249   393>
            , <&key_physical_attrs  95  95 357  368      0    0     0>
            , <&key_physical_attrs  95  95 469  370    200  519   420>
            , <&key_physical_attrs  95  95 817  370  (-200)  867   420>
            , <&key_physical_attrs  95  95 928  368      0    0     0>
            ;
    };

    aliases {
        led-red = &led0;
        led-green = &led1;
        led-blue = &led2;
    };

    leds {
        compatible = "gpio-leds";
        status = "okay";
        led0: led_0 {
            gpios = <&gpio1 15 GPIO_ACTIVE_HIGH>;
        };
        led1: led_1 {
            gpios = <&gpio1 14 GPIO_ACTIVE_HIGH>;
        };
        led2: led_2 {
            gpios = <&gpio0 10 GPIO_ACTIVE_HIGH>;
        };
    };
};

&uicr {
    nfct-pins-as-gpios;
};

&xiao_i2c {
    status = "disabled";
};

&xiao_serial {
    status = "disabled";
};
